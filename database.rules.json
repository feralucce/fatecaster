{
  "rules": {
    "rooms": {
      "$roomId": {
        // Only authenticated users who are participants can read room metadata.
        ".read": "auth != null && data.child('participants').child(auth.uid).exists()",

        // Only authenticated users can create a room; owner field must match their UID.
        ".write": "auth != null && (!data.exists() || data.child('ownerId').val() == auth.uid)",

        "participants": {
          "$userId": {
            // A participant can write (join/leave) only their own entry.
            ".write": "auth != null && auth.uid == $userId",
            ".read": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()"
          }
        },

        "rolls": {
          // All room participants can read rolls.
          ".read": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",

          "$rollId": {
            // A roll can only be written by the user identified in the roll's userId field.
            ".write": "auth != null && (!data.exists() && newData.child('userId').val() == auth.uid)",

            // Basic rate limiting: the timestamp must be a recent server value (within 60 s).
            ".validate": "newData.hasChildren(['userId','timestamp','rollResult','roomId']) && newData.child('userId').val() == auth.uid"
          }
        }
      }
    }
  }
}
